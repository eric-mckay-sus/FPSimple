@page "/"
@inject FPSampleDbContext DbContext

<PageTitle>Database Test</PageTitle>


<h3>Database Connection Test</h3>
<p class="text-muted">Fetching data from <code>ModelToLine</code> table...</p>

@if (_error != null)
{
    <div class="alert alert-danger">
        <strong>Connection Failed:</strong> @_error
    </div>
}
else if (MLData == null)
{
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body">
            @* Minimal usage of UniversalTable *@
            <UniversalTable T="ModelLine"
                            Items="MLData"
                            TotalCount="MLData.Count()"
                            PageSize="MLData.Count()"
                            CurrentPage="1"
                            TotalPages="1" />
        </div>
    </div>
    <div class="card shadow-sm">
        <div class="card-body">
            @* Minimal usage of UniversalTable *@
            <UniversalTable T="FoolproofEntry"
                            Items="FPData"
                            TotalCount="FPData.Count()"
                            PageSize="FPData.Count()"
                            CurrentPage="1"
                            TotalPages="1" />
        </div>
    </div>
}

@code {
    private IEnumerable<ModelLine>? MLData;
    private IEnumerable<FoolproofEntry>? FPData;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Simple query to verify the handshake and data retrieval
            MLData = await DbContext.ModelToLine.AsNoTracking().ToListAsync();
            FPData = await DbContext.FoolproofInfo.AsNoTracking().ToListAsync();

        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
